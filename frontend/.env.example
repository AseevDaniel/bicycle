# =============================================================
# BiciMarket Frontend (Next.js) - Environment Variables
# Copy to .env.local for local development
# Set directly in Hostinger panel for production
# =============================================================

# URLs — update with your actual domains for production
NEXT_PUBLIC_APP_URL=https://your-frontend-domain.com
NEXT_PUBLIC_API_URL=https://your-api-domain.com/v1

# App Info
NEXT_PUBLIC_APP_NAME=BiciMarket
NEXT_PUBLIC_APP_DESCRIPTION=The bicycle marketplace for Costa del Sol

# Feature Flags
NEXT_PUBLIC_FEATURE_AI=false
NEXT_PUBLIC_FEATURE_PAYMENTS=false
NEXT_PUBLIC_FEATURE_MAP=true
NEXT_PUBLIC_DEMO_MODE=true

# =============================================================
# TO ADD LATER
# =============================================================

# Maps (Mapbox)
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# Payments (Stripe)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key

# CDN (Cloudflare R2)
# NEXT_PUBLIC_CDN_URL=https://cdn.bicimarket.es

# Monitoring (Sentry)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
