# =============================================================
# BiciMarket Frontend (Next.js) - Environment Variables
# =============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BiciMarket
NEXT_PUBLIC_APP_DESCRIPTION=The bicycle marketplace for Costa del Sol

# API
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Maps (Mapbox) - Add later
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# Payments (Stripe) - Add later
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# CDN (Cloudflare R2) - Add later
# NEXT_PUBLIC_CDN_URL=https://cdn.bicimarket.es

# Analytics - Add later
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_VERCEL_ANALYTICS=true

# Auth - Add later
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# Feature Flags
NEXT_PUBLIC_FEATURE_AI=false
NEXT_PUBLIC_FEATURE_PAYMENTS=false
NEXT_PUBLIC_FEATURE_MAP=true
NEXT_PUBLIC_DEMO_MODE=true
