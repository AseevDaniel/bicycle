# =============================================================
# BiciMarket Backend (Fastify) - Environment Variables
# =============================================================

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (Neon PostgreSQL in prod)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bicimarket
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis (Upstash in prod)
REDIS_URL=redis://localhost:6379
REDIS_TTL_DEFAULT=3600

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterKey

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGINS=http://localhost:3000,https://bicimarket.es

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000

# File Upload (Cloudflare R2) - Add later
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=bicimarket-uploads
# R2_PUBLIC_URL=https://cdn.bicimarket.es

# AI (Claude API) - Add later
# ANTHROPIC_API_KEY=sk-ant-...
# AI_PHOTO_DAILY_LIMIT=500
# AI_SEARCH_DAILY_LIMIT=2000
# AI_PRICE_DAILY_LIMIT=5000

# Email (Resend) - Add later
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@bicimarket.es

# Stripe - Add later
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# OAuth - Add later
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# Monitoring
# SENTRY_DSN=
