# =============================================================
# BiciMarket API - Environment Variables
# Copy to .env for local development
# Set directly in Hostinger panel for production
# =============================================================

# Server
# NOTE: Hostinger sets PORT automatically — do not override it in production
PORT=4000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# CORS — set your frontend domain here
# Multiple domains: comma-separated
CORS_ORIGINS=https://your-frontend-domain.com

# Database (Neon PostgreSQL recommended for production)
# https://neon.tech — free tier available
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis (Upstash recommended for production)
# https://upstash.com — free tier available
REDIS_URL=redis://default:password@host:port

# Meilisearch (Meilisearch Cloud recommended for production)
# https://cloud.meilisearch.com — free tier available
MEILISEARCH_URL=https://your-instance.meilisearch.io
MEILISEARCH_MASTER_KEY=your-meilisearch-master-key

# JWT Secrets — generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000

# =============================================================
# TO ADD LATER
# =============================================================

# File Upload (Cloudflare R2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=bicimarket-uploads
# R2_PUBLIC_URL=https://cdn.bicimarket.es

# AI (Claude API)
# ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend)
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@bicimarket.es

# Payments (Stripe)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# Monitoring
# SENTRY_DSN=
